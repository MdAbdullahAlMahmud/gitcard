<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{repoName}} — gitsnap</title>
  <style>{{{styles}}}</style>
</head>
<body class="{{theme}}">
  <div class="card">

    <!-- Header -->
    <div class="header">
      {{#if github.avatarUrl}}
        <img class="avatar" src="{{github.avatarUrl}}" alt="{{github.owner}}" />
      {{else}}
        <div class="avatar-placeholder">📦</div>
      {{/if}}

      <div class="header-meta">
        <div class="repo-full-name">
          {{#if github}}{{github.owner}} / {{/if}}{{repoName}}
        </div>
        {{#if github.description}}
          <div class="repo-description">{{github.description}}</div>
        {{/if}}
      </div>

      <div class="header-right">
        {{#if packageVersion}}
          <span class="version-badge">v{{packageVersion}}</span>
        {{/if}}
        {{#if github.license}}
          <span class="license-badge">{{github.license}}</span>
        {{/if}}
      </div>
    </div>

    <!-- Language bar -->
    {{#if languages.length}}
    <div class="lang-section">
      <div class="lang-bar">
        {{#each languages}}
          <div class="lang-bar-segment" style="width: {{percentage}}%; background: {{color}};"></div>
        {{/each}}
      </div>
      <div class="lang-labels">
        {{#each languages}}
          <span class="lang-label">
            <span class="lang-dot" style="background: {{color}};"></span>
            <span class="lang-name">{{language}}</span>
            <span>{{formatPercent percentage}}%</span>
          </span>
        {{/each}}
      </div>
    </div>
    {{/if}}

    <!-- GitHub stats -->
    {{#if github}}
    <div class="github-stats">
      <span class="stat">
        <span class="stat-icon">★</span>
        <span class="stat-value">{{formatNum github.stars}}</span>
        <span>stars</span>
      </span>
      <span class="stat">
        <span class="stat-icon">⑂</span>
        <span class="stat-value">{{formatNum github.forks}}</span>
        <span>forks</span>
      </span>
      <span class="stat">
        <span class="stat-icon">●</span>
        <span class="stat-value">{{github.openIssues}}</span>
        <span>issues</span>
      </span>
      <span class="stat">
        <span class="stat-icon">👤</span>
        <span class="stat-value">{{contributorCount}}</span>
        <span>contributors</span>
      </span>
    </div>
    {{/if}}

    <!-- Repo stats -->
    <div class="repo-stats">
      <span class="stat">
        <span class="stat-icon">📁</span>
        <span class="stat-value">{{formatNum totalFiles}}</span>
        <span>files</span>
      </span>
      <span class="stat">
        <span class="stat-icon">💾</span>
        <span class="stat-value">{{totalSizeFormatted}}</span>
      </span>
      <span class="stat">
        <span class="stat-icon">📝</span>
        <span class="stat-value">{{formatNum totalCommits}}</span>
        <span>commits</span>
      </span>
      {{#if ageFormatted}}
      <span class="stat">
        <span class="stat-icon">🕐</span>
        <span>{{ageFormatted}}</span>
      </span>
      {{/if}}
      {{#if packageManager}}
      <span class="stat">
        <span class="stat-icon">📦</span>
        <span>{{packageManager}}</span>
        {{#if dependencyCount}}
        <span class="stat-value">· {{dependencyCount}} deps</span>
        {{/if}}
      </span>
      {{/if}}
    </div>

    <!-- Recent commits -->
    {{#if recentCommits.length}}
    <div class="commits-section">
      <div class="commits-label">Recent commits</div>
      {{#each recentCommits}}
        <div class="commit">
          <span class="commit-hash">{{hash}}</span>
          <span class="commit-msg">{{message}}</span>
          <span class="commit-date">{{relativeDate}}</span>
        </div>
      {{/each}}
    </div>
    {{/if}}

    <!-- Topics -->
    {{#if github.topics.length}}
    <div class="topics-section">
      <span class="topics-label">topics:</span>
      {{#each github.topics}}
        <span class="topic-tag">{{this}}</span>
      {{/each}}
    </div>
    {{/if}}

    <!-- Footer -->
    <div class="footer">
      <span class="footer-brand">⚡ Generated by gitsnap</span>
      <span class="footer-date">{{formatDate generatedAt}}</span>
    </div>

  </div>
</body>
</html>
